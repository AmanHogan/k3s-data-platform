# Example only 
# The minio/minio chart's `existingSecret` expects keys: rootUser, rootPassword.
#
# Create the REAL secret with kubectl (values stay off disk/out of git):
#
#   kubectl create secret generic minio-root -n data-platform \
#     --from-literal=rootUser=admin \
#     --from-literal=rootPassword="$(openssl rand -base64 24)"
#
# (Save the generated rootPassword somewhere safe — it's MinIO's admin login and
#  the S3 secret key your apps/mc will use.)
apiVersion: v1
kind: Secret
metadata:
  name: minio-root
  namespace: data-platform
type: Opaque
stringData:
  rootUser: admin
  rootPassword: replace-me-with-a-strong-secret
